# SHROUD environment template — copy to .env and fill in.
# .env is gitignored; NEVER commit real keys.

# Avalanche Fuji C-Chain (testnet)
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
CHAIN_ID=43113

# Funded deployer / relayer wallet. Generate with: python scripts/gen_key.py
# Fund the printed address from a Fuji faucet (https://faucet.avax.network/ or
# https://core.app/tools/testnet-faucet/) before deploying.
DEPLOYER_ADDRESS=0x0000000000000000000000000000000000000000
DEPLOYER_PRIVATE_KEY=0x...

# Deployed contract address (written by scripts/deploy.py after deployment)
SHROUD_CONTRACT_ADDRESS=
